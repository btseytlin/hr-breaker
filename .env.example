# =============================================================================
# Model Provider Selection
# =============================================================================
# Choose your provider: "anthropic", "openai", or "" (default = google/gemini)
# MODEL_PROVIDER=anthropic

# Model names (provider-specific)
# For Google/Gemini (default):
# GEMINI_PRO_MODEL=gemini/gemini-3-pro-preview
# GEMINI_FLASH_MODEL=gemini/gemini-3-flash-preview
# For Anthropic:
# GEMINI_PRO_MODEL=claude-sonnet-4-20250514
# GEMINI_FLASH_MODEL=claude-sonnet-4-20250514
# For OpenAI:
# GEMINI_PRO_MODEL=gpt-4o
# GEMINI_FLASH_MODEL=gpt-4o-mini

# Alternative model name vars (litellm format)
# PRO_MODEL=gemini/gemini-3-pro-preview
# FLASH_MODEL=gemini/gemini-3-flash-preview

# Embedding model (used for vector similarity filter, requires Google API key)
# EMBEDDING_MODEL=gemini/text-embedding-004

# Reasoning effort (none/low/medium/high) — only applies to Google/Gemini
# REASONING_EFFORT=medium

# =============================================================================
# API Keys (set for your chosen provider)
# =============================================================================

# Google/Gemini (default provider)
# GEMINI_API_KEY=your-key
# GOOGLE_API_KEY=your-key  # legacy alias

# Anthropic (direct or via Z.ai proxy)
# ANTHROPIC_API_KEY=your-key
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# OpenAI (direct or via proxy)
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
# OPENROUTER_API_KEY=your-key

# =============================================================================
# Example: Z.ai with Anthropic endpoint
# =============================================================================
# ANTHROPIC_API_KEY=your-z-ai-token
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_PROVIDER=anthropic
# GEMINI_PRO_MODEL=claude-sonnet-4-20250514
# GEMINI_FLASH_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Logging
# =============================================================================
# LOG_LEVEL=WARNING          # hr-breaker logger
# LOG_LEVEL_GENERAL=WARNING  # global

# =============================================================================
# Mode
# =============================================================================
# HR_BREAKER_FAST_MODE=true

# =============================================================================
# Scraper settings
# =============================================================================
# SCRAPER_HTTPX_TIMEOUT=15
# SCRAPER_WAYBACK_TIMEOUT=10
# SCRAPER_PLAYWRIGHT_TIMEOUT=30000
# SCRAPER_HTTPX_MAX_RETRIES=3
# SCRAPER_WAYBACK_MAX_AGE_DAYS=30
# SCRAPER_MIN_TEXT_LENGTH=200

# =============================================================================
# Filter thresholds
# =============================================================================
# FILTER_HALLUCINATION_THRESHOLD=0.9
# FILTER_KEYWORD_THRESHOLD=0.25
# FILTER_LLM_THRESHOLD=0.7
# FILTER_VECTOR_THRESHOLD=0.4
# FILTER_AI_GENERATED_THRESHOLD=0.4

# =============================================================================
# Resume length limits
# =============================================================================
# RESUME_MAX_CHARS=4500
# RESUME_MAX_WORDS=520
# RESUME_PAGE2_OVERFLOW_CHARS=1000

# =============================================================================
# Keyword matcher
# =============================================================================
# KEYWORD_TFIDF_MAX_FEATURES=200
# KEYWORD_TFIDF_CUTOFF=0.1
# KEYWORD_MAX_MISSING_DISPLAY=10

# =============================================================================
# Embedding settings
# =============================================================================
# EMBEDDING_OUTPUT_DIMENSIONALITY=768

# =============================================================================
# Agent limits
# =============================================================================
# AGENT_NAME_EXTRACTOR_CHARS=2000

# =============================================================================
# Translation (resume output language)
# =============================================================================
# DEFAULT_LANGUAGE=en
# TRANSLATION_MAX_ITERATIONS=2

# =============================================================================
# Retry settings (for rate limits / transient errors)
# =============================================================================
# RETRY_MAX_ATTEMPTS=5
# RETRY_MAX_WAIT=60

# =============================================================================
# CLI options (overridden by command-line flags)
# =============================================================================
# HR_BREAKER_OUTPUT=output
# HR_BREAKER_MAX_ITERATIONS=5
# HR_BREAKER_DEBUG=false
# HR_BREAKER_SEQ=false
# HR_BREAKER_NO_SHAME=false